# =============================================================================
# PEOPLES PRIORITIES — ENVIRONMENT VARIABLES REFERENCE
# =============================================================================
#
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to git (it is in .gitignore).
#
# TWO SEPARATE SYSTEMS:
#   VITE_*       → Frontend (Vite/React bundle) — Firebase Web SDK only
#   Non-VITE_*   → Server-side only (Vercel Serverless /api/* functions)
#
# =============================================================================


# =============================================================================
# SERVER-SIDE ONLY — Vercel Serverless /api/* endpoints
# Accessed via process.env inside api/analyze-report-image.ts etc.
# NEVER use import.meta.env for these.
# NEVER prefix these with VITE_.
# =============================================================================

# Your Gemini Developer API key (from Google AI Studio: aistudio.google.com)
GEMINI_API_KEY=

# Firebase Web API key — used for server-side Firebase ID token verification only
# Value is the same as VITE_FIREBASE_API_KEY but kept separate by convention
FIREBASE_WEB_API_KEY=

# Gemini model to use for each endpoint
# Recommended: gemini-2.5-flash (supports image, audio, and text multimodal)
GEMINI_IMAGE_MODEL=gemini-2.5-flash
GEMINI_AUDIO_MODEL=gemini-2.5-flash
GEMINI_TEXT_MODEL=gemini-2.5-flash


# =============================================================================
# FRONTEND — Vite/React (Firebase Web SDK configuration)
# Accessed via import.meta.env.VITE_* inside src/ components.
# These are public Firebase client identifiers — not secrets.
# =============================================================================

# Firebase Web SDK config (get these from Firebase Console → Project Settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
